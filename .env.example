# ============================================
# Pushakin Flows - Environment Variables
# ============================================

# --- DATABASE (Neon PostgreSQL) ---
# Dapatkan dari dashboard Neon: https://console.neon.tech
# Pilih project → Connection Details → Copy connection string
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# --- NEXTAUTH (Opsional - untuk autentikasi lanjutan) ---
# NEXTAUTH_URL="https://yourdomain.vercel.app"
# NEXTAUTH_SECRET="your-random-secret-key-min-32-chars"

# --- GOOGLE DRIVE (Opsional - untuk fitur upload file) ---
# Buat service account di Google Cloud Console
# https://console.cloud.google.com/iam-admin/serviceaccounts
# GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# GOOGLE_SHARED_DRIVE_ID="your-shared-drive-id"
# GOOGLE_API_KEY="your-google-api-key"

# --- APP CONFIG ---
# NODE_ENV="production"
